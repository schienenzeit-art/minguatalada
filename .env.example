# Kopiere diese Datei zu .env und fülle die Werte aus.
# .env wird NICHT eingecheckt (steht in .gitignore).

# ── PostgreSQL-Verbindung ─────────────────────────────────────────────────────
# Vollständige URL (hat Vorrang vor den Einzelparametern unten):
DATABASE_URL=postgresql://mgl_user:SICHERES_PASSWORT@100.x.y.z:5432/minguatalada

# Alternativ Einzelparameter (werden zu DATABASE_URL zusammengesetzt):
# DB_HOST=100.x.y.z          # Tailscale-IP des Raspberry Pi
# DB_PORT=5432
# DB_NAME=minguatalada
# DB_USER=mgl_user
# DB_PASSWORD=SICHERES_PASSWORT

# ── App-Sicherheit ───────────────────────────────────────────────────────────
APP_SECRET_KEY=bitte-einen-langen-zufaelligen-string-setzen

# ── SQLite-Fallback ──────────────────────────────────────────────────────────
# DATABASE_URL weglassen (oder auskommentieren) um SQLite zu verwenden.
# Nützlich für lokale Entwicklung ohne PostgreSQL-Server.
